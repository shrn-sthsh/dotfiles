# Set leader combination
set -g prefix C-f


# Reduce escape sequence time
set -sg escape-time 10


# Reload TMUX config with <leader>+r
unbind r
bind r source-file ~/.tmux.conf


# Toggle mouse control
set -g mouse on
bind -T copy-mode-vi C-WheelUpPane   send-keys -X halfpage-up
bind -T copy-mode-vi C-WheelDownPane send-keys -X halfpage-down


# Split windows with parent window directory
bind '"' split-window -c    "#{pane_current_path}"
bind  %  split-window -h -c "#{pane_current_path}"
bind  +  new-window   -c    "#{pane_current_path}"


# Toggle clipboard control
set -g set-clipboard on

# shortcut keys
bind-key -T copy-mode-vi v send -X begin-selection
bind-key -T copy-mode-vi V send -X select-line

# clipboard client by OS
if-shell 'command -v pbcopy > /dev/null 2>&1' \
  'bind-key -T copy-mode-vi y send -X copy-pipe-and-cancel "pbcopy"'

if-shell 'command -v clip.exe > /dev/null 2>&1' \
  'bind-key -T copy-mode-vi y send -X copy-pipe-and-cancel "clip.exe"'

if-shell 'command -v wl-copy > /dev/null 2>&1' \
  'bind-key -T copy-mode-vi y send -X copy-pipe-and-cancel "wl-copy"'

if-shell 'command -v xsel > /dev/null 2>&1' \
  'bind-key -T copy-mode-vi y send -X copy-pipe-and-cancel "xsel -b -i"'


# Set color options
set -g default-terminal "linux"

# tell Tmux that outside terminal supports true color
set -ga terminal-overrides ",linux*:Tc"
set -option -ga terminal-overrides ",xterm-256color:Tx"


# Update X session variables
set -g command-alias[100] 'display=run-shell ~/.tmux/scripts/update-display.sh'
bind-key u run-shell "~/.tmux/scripts/update-display.sh"
set-hook -g client-attached 'run-shell $dot/packages/tmux/scripts/update-display.sh'


# Set status bar
set-option -g status on
set-option -g status-interval 1
set-option -g status-justify centre
set-option -g status-keys vi
set-option -g status-position bottom
set-option -g status-style fd=red,bg=colour235

set-option -g status-left-length 30
set-option -g status-left-style default
set-option -g status-left "#[fg=white]#[fg=cyan]#H#[fg=white] @ #[fg=blue, bright]#S#[default]"

set-option -g status-right-length 155
set-option -g status-right-style default
set-option -g status-right "#[fg=green]%Y-%m-%d #[fg=yellow, bright]%H:%M:%S#[fg=white]"

set-window-option -g window-status-style fg=colour244
set-window-option -g window-status-style bg=default
set-window-option -g window-status-current-style fg=colour166
set-window-option -g window-status-current-style bg=default


# Toggle vim pane control
bind-key h select-pane -L
bind-key j select-pane -D
bind-key k select-pane -U
bind-key l select-pane -R

bind-key -r h resize-pane -L
bind-key -r j resize-pane -D
bind-key -r k resize-pane -U
bind-key -r l resize-pane -R

unbind Up
unbind Down
unbind Left
unbind Right

unbind C-Up
unbind C-Down
unbind C-Left
unbind C-Right


# Set path for status bar
set-window-option -g pane-border-status top
set-window-option -g pane-border-format '#{pane_current_path}'

